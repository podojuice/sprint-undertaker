#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_PATH="${IDLE_RPG_CODEX_CONFIG:-$HOME/.config/idle-rpg/codex-wrapper.env}"
SESSION_ID="codex-$(date +%s)-$$"
STARTED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
START_EPOCH="$(date +%s)"
CLIENT_VERSION="0.1.0"
PROJECT_HASH="$(pwd | shasum | awk '{print $1}')"

if [[ -f "$CONFIG_PATH" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_PATH"
fi

SERVER_URL="${IDLE_RPG_SERVER_URL:-}"
API_KEY="${IDLE_RPG_API_KEY:-}"
CODEX_REAL_BIN="${CODEX_REAL_BIN:-}"

if [[ -z "$CODEX_REAL_BIN" ]]; then
  echo "CODEX_REAL_BIN is not set. Re-run install.sh or update $CONFIG_PATH." >&2
  exit 1
fi

if [[ ! -x "$CODEX_REAL_BIN" ]]; then
  echo "Configured CODEX_REAL_BIN is not executable: $CODEX_REAL_BIN" >&2
  exit 1
fi

send_event() {
  local event_type="$1"
  local metrics_json="$2"
  local occurred_at="$3"

  if [[ -z "$SERVER_URL" || -z "$API_KEY" ]]; then
    return 0
  fi

  python3 - "$SERVER_URL" "$API_KEY" "$SESSION_ID" "$event_type" "$occurred_at" "$metrics_json" "$CLIENT_VERSION" <<'PY'
import json
import sys
from urllib import request

server_url, api_key, session_id, event_type, occurred_at, metrics_json, client_version = sys.argv[1:]
payload = {
    "provider": "codex",
    "event_type": event_type,
    "session_id": session_id,
    "occurred_at": occurred_at,
    "metrics": json.loads(metrics_json),
    "metadata": {
        "client_version": client_version,
        "project_hash": json.loads(metrics_json).get("project_hash"),
    },
}
body = json.dumps(payload).encode()
req = request.Request(
    f"{server_url.rstrip('/')}/api/events",
    data=body,
    headers={
        "Content-Type": "application/json",
        "X-API-Key": api_key,
    },
    method="POST",
)
try:
    with request.urlopen(req, timeout=3) as response:
        content = response.read().decode()
        if content:
            data = json.loads(content)
            for message in data.get("notifications", []):
                print(f"[idle-rpg] {message}", file=sys.stderr)
except Exception:
    pass
PY
}

git_repo_available() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

capture_change_snapshot() {
  if ! git_repo_available; then
    echo '{"available": false}'
    return 0
  fi

  python3 - <<'PY'
import json
import subprocess


def run(command):
    return subprocess.run(command, capture_output=True, text=True, check=False)


def tracked_totals():
    diff = run(["git", "diff", "--numstat", "--no-ext-diff", "HEAD", "--"])
    lines_added = 0
    lines_deleted = 0
    files_changed = 0
    for raw_line in diff.stdout.splitlines():
        parts = raw_line.split("\t", 2)
        if len(parts) < 3:
            continue
        added, deleted, _path = parts
        if added == "-" or deleted == "-":
            continue
        lines_added += int(added)
        lines_deleted += int(deleted)
        files_changed += 1
    return lines_added, lines_deleted, files_changed


def untracked_totals():
    files = run(["git", "ls-files", "--others", "--exclude-standard"]).stdout.splitlines()
    lines = 0
    for path in files:
        result = run(["wc", "-l", path])
        if result.returncode != 0:
            continue
        try:
            lines += int(result.stdout.strip().split()[0])
        except (ValueError, IndexError):
            continue
    return len(files), lines


tracked_added, tracked_deleted, tracked_files = tracked_totals()
untracked_files, untracked_lines = untracked_totals()

print(json.dumps({
    "available": True,
    "tracked_lines_added": tracked_added,
    "tracked_lines_deleted": tracked_deleted,
    "tracked_files_changed": tracked_files,
    "untracked_files": untracked_files,
    "untracked_lines": untracked_lines,
}))
PY
}

compute_code_change_metrics() {
  python3 - "$1" "$2" "$PROJECT_HASH" <<'PY'
import json
import sys

before = json.loads(sys.argv[1])
after = json.loads(sys.argv[2])
project_hash = sys.argv[3]

if not before.get("available") or not after.get("available"):
    print(json.dumps({
        "files_changed": 0,
        "lines_added": 0,
        "lines_deleted": 0,
        "project_hash": project_hash,
        "measurement": "unavailable",
    }))
    raise SystemExit(0)

tracked_added_delta = after["tracked_lines_added"] - before["tracked_lines_added"]
tracked_deleted_delta = after["tracked_lines_deleted"] - before["tracked_lines_deleted"]
tracked_files_delta = after["tracked_files_changed"] - before["tracked_files_changed"]
untracked_files_delta = after["untracked_files"] - before["untracked_files"]
untracked_lines_delta = after["untracked_lines"] - before["untracked_lines"]

lines_added = max(0, tracked_added_delta) + max(0, untracked_lines_delta)
lines_deleted = max(0, tracked_deleted_delta)
files_changed = max(0, tracked_files_delta) + max(0, untracked_files_delta)

print(json.dumps({
    "files_changed": files_changed,
    "lines_added": lines_added,
    "lines_deleted": lines_deleted,
    "project_hash": project_hash,
    "measurement": "git_worktree_delta",
}))
PY
}

CHANGE_SNAPSHOT_BEFORE="$(capture_change_snapshot)"

SESSION_STARTED_METRICS="$(python3 - "$PROJECT_HASH" <<'PY'
import json
import sys
print(json.dumps({
    "tool_name": "codex",
    "project_hash": sys.argv[1],
}))
PY
)"
send_event "session_started" "$SESSION_STARTED_METRICS" "$STARTED_AT"

set +e
"$CODEX_REAL_BIN" "$@"
COMMAND_EXIT=$?
set -e

ENDED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
END_EPOCH="$(date +%s)"
DURATION_SECONDS="$((END_EPOCH - START_EPOCH))"
CHANGE_SNAPSHOT_AFTER="$(capture_change_snapshot)"
CODE_CHANGE_METRICS="$(compute_code_change_metrics "$CHANGE_SNAPSHOT_BEFORE" "$CHANGE_SNAPSHOT_AFTER")"

if python3 - "$CODE_CHANGE_METRICS" <<'PY'
import json
import sys

metrics = json.loads(sys.argv[1])
raise SystemExit(0 if metrics.get("files_changed", 0) > 0 or metrics.get("lines_added", 0) > 0 or metrics.get("lines_deleted", 0) > 0 else 1)
PY
then
  send_event "code_applied" "$CODE_CHANGE_METRICS" "$ENDED_AT"
fi

COMMAND_METRICS="$(python3 - "$COMMAND_EXIT" "$DURATION_SECONDS" "$PROJECT_HASH" <<'PY'
import json
import sys
exit_code = int(sys.argv[1])
duration = int(sys.argv[2])
print(json.dumps({
    "command_success": exit_code == 0,
    "exit_code": exit_code,
    "duration_seconds": duration,
    "project_hash": sys.argv[3],
}))
PY
)"
send_event "command_finished" "$COMMAND_METRICS" "$ENDED_AT"
send_event "session_ended" "$(python3 - "$DURATION_SECONDS" "$PROJECT_HASH" <<'PY'
import json
import sys
print(json.dumps({
    "duration_seconds": int(sys.argv[1]),
    "project_hash": sys.argv[2],
}))
PY
)" "$ENDED_AT"

exit "$COMMAND_EXIT"
